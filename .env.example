# Supabase project URL and anon key for client-side auth and data access.
# Important: VITE_* variables are injected at build time.
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Node runtime variables for production server (Namecheap/cPanel)
# NODE_ENV="production"
# PORT="3000"

# Optional for local/dev direct Gemini access from the browser.
# Note: this exposes the key to the client, so prefer the Supabase Edge Function for production.
# VITE_GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
# VITE_GEMINI_MODEL="gemini-2.5-flash"

# Supabase Edge Function secret to set on the server:
# supabase secrets set GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
# Optional server-side model override:
# supabase secrets set GEMINI_MODEL="gemini-2.5-flash"

# Home hero text overrides (optional)
# VITE_HOME_HERO_BADGE="SEASON 2026 IS HERE"
# VITE_HOME_HERO_LINE_ONE="Farm Fresh"
# VITE_HOME_HERO_HIGHLIGHT="Mangoes"
# VITE_HOME_HERO_LINE_TWO="for Every Doorstep"
# VITE_HOME_HERO_DESCRIPTION="Straight from Podaganj's legendary red-soil farms, our hand-picked Harivanga mangoes arrive tree-ripened, chemical-free, and packed for a premium fresh-fruit experience."
